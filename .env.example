# ─── AgriGuard Environment Template ────────────────────────────────────────
# Copy this file to .env and fill in your values before running docker compose.

# ── Database ────────────────────────────────────────────────────────────────
# PostgreSQL password used by both the db service and the backend connection string
POSTGRES_PASSWORD=agrishield2026

# Full connection string (used by backend directly, override if using external DB)
DATABASE_URL=postgresql://postgres:agrishield2026@db:5432/agri_fraud

# ── ML Model ────────────────────────────────────────────────────────────────
MODEL_PATH=/app/models/fraud_detector.pkl
DATA_DIR=/app/data

# ── API Security ────────────────────────────────────────────────────────────
# This key must match VITE_API_KEY in the frontend build.
# Leave blank to disable auth (dev mode).
API_KEY=agrishield-dev-2026

# ── Frontend ─────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
VITE_API_KEY=agrishield-dev-2026

# Clerk authentication (optional — leave as-is to run without auth)
VITE_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key_here

# ── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost,http://localhost:5173,http://localhost:3000
